---
// Self-hosted fonts (imprint promises no third-party requests). Archivo
// ships the wdth+wght axes — the width axis is used on the poster headline.
// Browsers fetch only the latin subset via unicode-range.
import "@fontsource-variable/archivo/wdth.css";
import "@fontsource/fragment-mono";
import "../styles/tokens.css";
import "../styles/global.css";
import { flattenTokens, ACCENT_RAMP_STEPS } from "../lib/tokens";
import pkg from "../../package.json";
import contact from "../data/contact.json";
import ThemePanel from "../components/ThemePanel.tsx";
import { tokenTiers } from "../lib/token-tiers";

const tiers = tokenTiers();

// Colophon facts, computed from the same sources everything else uses.
const tokenModules = import.meta.glob<{
  default: Parameters<typeof flattenTokens>[0];
}>("../../tokens/**/*.tokens.json", { eager: true });
const tokenCount = new Set(
  Object.values(tokenModules).flatMap((mod) =>
    flattenTokens(mod.default).map((token) => token.path),
  ),
).size;

interface Props {
  /** Page title, appended with the site name. */
  title: string;
  /** Meta description for search engines and previews. */
  description: string;
}

const { title, description } = Astro.props;

// Follows the route locale once /de pages exist; "en" until then.
const locale = Astro.currentLocale ?? "en";

const navItems = [
  { href: "/", label: "Work" },
  { href: "/notes", label: "Notes" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} Portfolio Michael Giang</title>
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <!--
      Apply persisted theming before first paint (no flash of wrong theme).
      Storage keys (shared with the ThemePanel island in phase 4):
        pref-theme:   "light" | "dark"        -> data-theme on <html>
        pref-density: "tight" | "normal" | "comfy" -> data-density on <html>
        pref-hue:     "0".."360"              -> --hue on <html>
      Unset keys fall back to CSS defaults (system color scheme, normal
      density, hue 220) — the site stays fully usable without JS.
    -->
    <script is:inline>
      (() => {
        try {
          const html = document.documentElement;
          const theme = localStorage.getItem("pref-theme");
          if (theme === "light" || theme === "dark") {
            html.dataset.theme = theme;
          }
          const density = localStorage.getItem("pref-density");
          if (density === "tight" || density === "comfy") {
            html.dataset.density = density;
          }
          const rawHue = localStorage.getItem("pref-hue");
          const hue = rawHue === null ? NaN : Number(rawHue);
          if (Number.isFinite(hue) && hue >= 0 && hue <= 360) {
            html.style.setProperty("--hue", String(hue));
          }
        } catch {
          /* storage unavailable (e.g. blocked) -> defaults apply */
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header class="site-bar">
      <a href="/" class="site-bar__monogram" aria-label="Michael Giang — home">
        <img
          src="/public/navbar-logo-light.png"
          alt=""
          class="site-bar__mark site-bar__mark--light"
        />
        <img
          src="/public/navbar-logo-dark.png"
          alt=""
          class="site-bar__mark site-bar__mark--dark"
        />
      </a>
      <nav class="site-bar__nav" aria-label="Main navigation">
        <ul class="site-bar__list">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="site-bar__link"
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <button
        class="site-bar__hue"
        popovertarget="theme-popover"
        aria-label="Theme settings"
        data-tooltip="Theme settings"
      >
        <span class="site-bar__swatch" aria-hidden="true"></span>
      </button>
      <token-inspector
        compact
        class="site-bar__inspector"
        tiers={JSON.stringify(tiers)}></token-inspector>
      <a
        class="site-bar__contact"
        href={`mailto:${contact.email}`}
        data-copy-email={contact.email}
      >
        <span data-contact-label>Contact</span>
      </a>
    </header>
    <div id="theme-popover" class="theme-popover" popover>
      <ThemePanel client:idle />
    </div>
    <noscript>
      <style>
        /* Theming and the inspector are JS enhancements; without JS the
           popover would be empty and the custom element never upgrades. */
        .site-bar__hue,
        .site-bar__inspector {
          display: none;
        }
      </style>
    </noscript>
    <main id="main" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__ramp" aria-hidden="true">
        {
          ACCENT_RAMP_STEPS.map((step) => (
            <span style={`background: var(--color-accent-${step})`} />
          ))
        }
      </div>
      <div class="site-footer__content">
        <p class="site-footer__note">
          <code>v{pkg.version}</code> · <code>{tokenCount} tokens</code> · Astro +
          React + Lit — <a href="/system">how this site is built</a>
        </p>
        <p class="site-footer__links">
          <a href={contact.github}>GitHub</a> ·
          <a href={contact.linkedin}>LinkedIn</a> ·
          <a href={`mailto:${contact.email}`}>Email</a> ·
          <a href="/imprint">Imprint</a>
        </p>
        <p class="site-footer__copyright">© 2026 Michael Giang</p>
      </div>
    </footer>
  </body>
</html>

<script>
  // Registers <token-inspector> for the instrument bar (site-wide).
  import "../components/TokenInspector";

  // Contact: on precise pointers, copy the address instead of launching a
  // mail client that is often unconfigured on desktops. The plain mailto
  // stays the no-JS and touch fallback (mail apps work well there).
  // Several copy buttons can exist (instrument bar, home outro).
  if (navigator.clipboard && matchMedia("(pointer: fine)").matches) {
    for (const link of document.querySelectorAll<HTMLAnchorElement>(
      "[data-copy-email]",
    )) {
      const label = link.querySelector<HTMLElement>("[data-contact-label]");
      if (!label) continue;
      const original = label.textContent;
      let resetTimer = 0;
      link.addEventListener("click", (event) => {
        event.preventDefault();
        navigator.clipboard
          .writeText(link.dataset.copyEmail ?? "")
          .then(() => {
            label.textContent = "copied ✓";
            window.clearTimeout(resetTimer);
            resetTimer = window.setTimeout(() => {
              label.textContent = original;
            }, 1600);
          })
          .catch(() => {
            // Clipboard blocked — fall back to the mail client after all.
            window.location.href = link.href;
          });
      });
    }
  }
</script>

<style>
  /* Instrument bar: sticky, content-axis aligned, deliberately not full
     width — flat surface and hairline instead of blur/shadow. */
  .site-bar {
    position: sticky;
    inset-block-start: var(--space-stack-xs);
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-inline-lg);
    inline-size: fit-content;
    max-inline-size: calc(100vw - 2 * var(--space-inset-md));
    margin-block-start: var(--space-stack-sm);
    margin-inline: auto;
    padding: var(--space-inset-xs) var(--space-inset-md);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-default);
  }

  .site-bar__monogram {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-bar__mark {
    height: var(--font-size-800);
    width: auto;
  }
  /* Default: helles Theme -> Light-Marke */
  .site-bar__mark--dark {
    display: none;
  }

  /* Explizit dunkel */
  [data-theme="dark"] .site-bar__mark--light {
    display: none;
  }
  [data-theme="dark"] .site-bar__mark--dark {
    display: inline;
  }

  /* System dunkel, solange nicht explizit auf hell gestellt (No-JS-Default) */
  @media (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) .site-bar__mark--light {
      display: none;
    }
    html:not([data-theme="light"]) .site-bar__mark--dark {
      display: inline;
    }
  }

  .site-bar__list {
    display: flex;
    gap: var(--space-inline-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-bar__link {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .site-bar__link:hover {
    color: var(--color-interactive-hover);
  }

  .site-bar__link[aria-current="page"] {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }

  .site-bar__hue {
    position: relative;
    display: grid;
    place-items: center;
    padding: var(--space-inset-xs);
    background: none;
    border: none;
    cursor: pointer;
  }

  /* Tooltip: token-styled label below the trigger, on hover and keyboard
     focus. Pure CSS — the accessible name stays on aria-label. Shares the
     visual contract with the inspector's tooltip via the same tokens. */
  .site-bar__hue::after {
    content: attr(data-tooltip);
    position: absolute;
    inset-block-start: calc(100% + var(--space-stack-xs));
    inset-inline-start: 50%;
    translate: -50% 0;
    z-index: 60;
    padding: var(--space-inset-xs) var(--space-inset-sm);
    background: var(--color-surface-raised);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-surface);
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    line-height: var(--typography-label-line-height);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--motion-state-duration) var(--motion-state-easing);
  }

  .site-bar__hue:hover::after,
  .site-bar__hue:focus-visible::after {
    opacity: 1;
  }

  /* Live accent swatch — the filled square motif, showing the current hue. */
  .site-bar__swatch {
    display: block;
    inline-size: 1em;
    block-size: 1em;
    background: var(--color-surface-accent);
    border: 1px solid var(--color-border-strong);
  }

  .site-bar__contact {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    padding: var(--space-inset-xs) var(--space-inset-md);
    background: var(--button-primary-background);
    color: var(--button-primary-text);
    text-decoration: none;
    transition: background-color var(--motion-state-duration)
      var(--motion-state-easing);
  }

  .site-bar__contact:hover {
    background: var(--button-primary-background-hover);
    color: var(--button-primary-text);
  }

  /* Narrow screens: tighter rhythm so the bar stays a single line.
     After the base rules — equal specificity, source order decides. */
  @media (max-width: 30rem) {
    .site-bar {
      gap: var(--space-inline-sm);
      padding-inline: var(--space-inset-sm);
    }

    .site-bar__list {
      gap: var(--space-inline-sm);
    }

    .site-bar__contact {
      padding-inline: var(--space-inset-sm);
    }

    /* The inspector is a hover/focus lens — pointless on touch, and the
       square would cost the single-line budget. */
    .site-bar__inspector {
      display: none;
    }
  }

  /* Theme popover: top layer, centered under the bar like the bar itself.
     The panel inside brings its own surface. */
  .theme-popover {
    position: fixed;
    inset: unset;
    inset-block-start: calc(var(--space-stack-sm) + var(--space-stack-xl));
    inset-inline: 0;
    inline-size: fit-content;
    margin-block: 0;
    margin-inline: auto;
    padding: 0;
    border: none;
    background: none;
    overflow: visible;
  }

  .site-main {
    max-width: 72rem;
    margin-inline: auto;
    padding: var(--space-stack-xl) var(--space-inset-lg);
  }

  /* The poster's ramp returns as the site's closing edge — it follows the
     hue like everything else. */
  .site-footer__ramp {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    block-size: var(--space-stack-md);
  }

  .site-footer__content {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-inline-lg);
    padding: var(--space-inset-lg);
    color: var(--color-text-secondary);
    font-size: var(--font-size-200);
  }

  .site-footer__links {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
  }
</style>
