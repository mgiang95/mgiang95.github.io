---
// Self-hosted fonts (imprint promises no third-party requests). Archivo
// ships the wdth+wght axes — the width axis is used on the poster headline.
// Browsers fetch only the latin subset via unicode-range.
import "@fontsource-variable/archivo/wdth.css";
import "@fontsource/fragment-mono";
import "../styles/tokens.css";
import "../styles/global.css";
import { flattenTokens } from "../lib/tokens";
import pkg from "../../package.json";
import contact from "../data/contact.json";
import ThemePanel from "../components/ThemePanel.tsx";

// Colophon facts, computed from the same sources everything else uses.
const tokenModules = import.meta.glob<{
  default: Parameters<typeof flattenTokens>[0];
}>("../../tokens/**/*.tokens.json", { eager: true });
const tokenCount = new Set(
  Object.values(tokenModules).flatMap((mod) =>
    flattenTokens(mod.default).map((token) => token.path),
  ),
).size;

interface Props {
  /** Page title, appended with the site name. */
  title: string;
  /** Meta description for search engines and previews. */
  description: string;
}

const { title, description } = Astro.props;

// Follows the route locale once /de pages exist; "en" until then.
const locale = Astro.currentLocale ?? "en";

const navItems = [
  { href: "/", label: "Work" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Michael Giang</title>
    <!--
      Apply persisted theming before first paint (no flash of wrong theme).
      Storage keys (shared with the ThemePanel island in phase 4):
        pref-theme:   "light" | "dark"        -> data-theme on <html>
        pref-density: "tight" | "normal" | "comfy" -> data-density on <html>
        pref-hue:     "0".."360"              -> --hue on <html>
      Unset keys fall back to CSS defaults (system color scheme, normal
      density, hue 220) — the site stays fully usable without JS.
    -->
    <script is:inline>
      (() => {
        try {
          const html = document.documentElement;
          const theme = localStorage.getItem("pref-theme");
          if (theme === "light" || theme === "dark") {
            html.dataset.theme = theme;
          }
          const density = localStorage.getItem("pref-density");
          if (density === "tight" || density === "comfy") {
            html.dataset.density = density;
          }
          const rawHue = localStorage.getItem("pref-hue");
          const hue = rawHue === null ? NaN : Number(rawHue);
          if (Number.isFinite(hue) && hue >= 0 && hue <= 360) {
            html.style.setProperty("--hue", String(hue));
          }
        } catch {
          /* storage unavailable (e.g. blocked) -> defaults apply */
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header class="site-bar">
      <a href="/" class="site-bar__monogram" aria-label="Michael Giang — home">
        MG
      </a>
      <nav class="site-bar__nav" aria-label="Main navigation">
        <ul class="site-bar__list">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="site-bar__link"
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <button
        class="site-bar__hue"
        popovertarget="theme-popover"
        aria-label="Theme settings"
      >
        <span class="site-bar__swatch" aria-hidden="true"></span>
      </button>
      <a
        class="site-bar__contact"
        href={`mailto:${contact.email}`}
        data-copy-email={contact.email}
      >
        <span data-contact-label>Contact</span>
      </a>
    </header>
    <div id="theme-popover" class="theme-popover" popover>
      <ThemePanel client:idle />
    </div>
    <noscript>
      <style>
        /* Theming is a JS enhancement; without it the popover would be empty. */
        .site-bar__hue {
          display: none;
        }
      </style>
    </noscript>
    <main id="main" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p class="site-footer__note">
        <code>v{pkg.version}</code> · <code>{tokenCount} tokens</code> ·
        Astro + React + Lit — <a href="/system">how this site is built</a>
      </p>
      <p class="site-footer__copyright">
        © 2026 Michael Giang · <a href="/imprint">Imprint</a>
      </p>
    </footer>
  </body>
</html>

<script>
  // Contact: on precise pointers, copy the address instead of launching a
  // mail client that is often unconfigured on desktops. The plain mailto
  // stays the no-JS and touch fallback (mail apps work well there).
  const contactLink = document.querySelector<HTMLAnchorElement>("[data-copy-email]");
  const contactLabel = contactLink?.querySelector<HTMLElement>("[data-contact-label]");
  if (
    contactLink &&
    contactLabel &&
    navigator.clipboard &&
    matchMedia("(pointer: fine)").matches
  ) {
    let resetTimer = 0;
    contactLink.addEventListener("click", (event) => {
      event.preventDefault();
      navigator.clipboard
        .writeText(contactLink.dataset.copyEmail ?? "")
        .then(() => {
          contactLabel.textContent = "copied ✓";
          window.clearTimeout(resetTimer);
          resetTimer = window.setTimeout(() => {
            contactLabel.textContent = "Contact";
          }, 1600);
        })
        .catch(() => {
          // Clipboard blocked — fall back to the mail client after all.
          window.location.href = contactLink.href;
        });
    });
  }
</script>

<style>
  /* Instrument bar: sticky, content-axis aligned, deliberately not full
     width — flat surface and hairline instead of blur/shadow. */
  .site-bar {
    position: sticky;
    inset-block-start: var(--space-stack-xs);
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-inline-lg);
    inline-size: fit-content;
    max-inline-size: calc(100vw - 2 * var(--space-inset-md));
    margin-block-start: var(--space-stack-sm);
    /* Exact text axis of the 72rem content column (incl. its inset).
       Percent instead of vw: vw includes the scrollbar, layout does not. */
    margin-inline-start: calc(max(0px, (100% - 72rem) / 2) + var(--space-inset-lg));
    padding: var(--space-inset-xs) var(--space-inset-md);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-default);
  }

  .site-bar__monogram {
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-bold);
    /* The poster's expanded cut, reused as the mark. */
    font-stretch: 115%;
    font-size: var(--font-size-400);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .site-bar__list {
    display: flex;
    gap: var(--space-inline-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-bar__link {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .site-bar__link:hover {
    color: var(--color-interactive-hover);
  }

  .site-bar__link[aria-current="page"] {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }

  .site-bar__hue {
    display: grid;
    place-items: center;
    padding: var(--space-inset-xs);
    background: none;
    border: none;
    cursor: pointer;
  }

  /* Live accent swatch — the filled square motif, showing the current hue. */
  .site-bar__swatch {
    display: block;
    inline-size: 1em;
    block-size: 1em;
    background: var(--color-surface-accent);
    border: 1px solid var(--color-border-strong);
  }

  .site-bar__contact {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    padding: var(--space-inset-xs) var(--space-inset-md);
    background: var(--button-primary-background);
    color: var(--button-primary-text);
    text-decoration: none;
    transition: background-color var(--motion-state-duration)
      var(--motion-state-easing);
  }

  .site-bar__contact:hover {
    background: var(--button-primary-background-hover);
    color: var(--button-primary-text);
  }

  /* Narrow screens: tighter rhythm so the bar stays a single line.
     After the base rules — equal specificity, source order decides. */
  @media (max-width: 30rem) {
    .site-bar {
      gap: var(--space-inline-sm);
      padding-inline: var(--space-inset-sm);
    }

    .site-bar__list {
      gap: var(--space-inline-sm);
    }

    .site-bar__contact {
      padding-inline: var(--space-inset-sm);
    }
  }

  /* Theme popover: top layer, anchored under the bar on the same axis.
     The panel inside brings its own surface. */
  .theme-popover {
    position: fixed;
    inset: unset;
    inset-block-start: calc(var(--space-stack-sm) + var(--space-stack-xl));
    inset-inline-start: calc(max(0px, 50vw - 36rem) + var(--space-inset-lg));
    margin: 0;
    padding: 0;
    border: none;
    background: none;
    overflow: visible;
  }

  .site-main {
    max-width: 72rem;
    margin-inline: auto;
    padding: var(--space-stack-xl) var(--space-inset-lg);
  }

  .site-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-inline-lg);
    padding: var(--space-inset-lg);
    border-block-start: 1px solid var(--color-border-default);
    color: var(--color-text-secondary);
    font-size: var(--font-size-200);
  }
</style>
