---
/**
 * ProjectRow — editorial index row for one case study: full-width,
 * hairline-separated, image beside large type. Replaces the card grid;
 * reads like a magazine table of contents. Consumes semantic tokens only;
 * the hover top edge reuses the poster's flat accent motif.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Badge from "./Badge.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, subtitle, description, summary, period, keywords, heroImage } =
  project.data;
// `description` doubles as the page's meta description and stays short; a row
// may carry a longer paragraph via `summary`.
const paragraph = summary ?? description;
---

<article class="project-row">
  <a class="project-row__link" href={`/projects/${project.id}`}>
    {
      heroImage && (
        <Image
          class="project-row__image"
          src={heroImage}
          alt=""
          widths={[480, 800, 1200]}
          sizes="(min-width: 60rem) 28rem, 100vw"
        />
      )
    }
    <div class="project-row__content">
      <h3 class="project-row__title">{title}</h3>
      <p class="project-row__meta">
        <span class="project-row__subtitle">{subtitle}</span>
        <span class="project-row__period">{period}</span>
      </p>
      <p class="project-row__description">{paragraph}</p>
      <ul class="project-row__keywords" aria-label="Key areas">
        {
          keywords.map((keyword) => (
            <li>
              <Badge>{keyword}</Badge>
            </li>
          ))
        }
      </ul>
    </div>
  </a>
</article>

<style>
  .project-row {
    border-block-start: 2px solid var(--color-border-default);
    transition: border-color var(--motion-state-duration)
      var(--motion-state-easing);
  }

  .project-row:last-of-type {
    border-block-end: 1px solid var(--color-border-default);
  }

  .project-row:hover {
    border-block-start-color: var(--color-surface-accent);
  }

  .project-row__link {
    display: grid;
    gap: var(--space-stack-md);
    padding-block: var(--space-stack-lg);
    color: inherit;
    text-decoration: none;
  }

  @media (min-width: 60rem) {
    .project-row__link {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      column-gap: var(--space-inline-xl);
      align-items: start;
    }
  }

  .project-row__image {
    inline-size: 100%;
    block-size: auto;
    border: 1px solid var(--color-border-default);
  }

  .project-row__content {
    display: grid;
    gap: var(--space-stack-sm);
    justify-items: start;
  }

  /* One mono line under the title: product, client, period — the facts that
     place the case, kept apart from the prose below. */
  .project-row__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-lg);
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
  }

  .project-row__title {
    font-size: var(--typography-heading-lg-size);
    line-height: var(--typography-heading-lg-line-height);
    transition: color var(--motion-state-duration) var(--motion-state-easing);
  }

  .project-row__link:hover .project-row__title {
    color: var(--color-interactive-hover);
  }

  .project-row__subtitle {
    max-width: 45ch;
    color: var(--color-text-secondary);
  }

  .project-row__period {
    white-space: nowrap;
  }

  /* The paragraph carries the case: what the product is, what was wrong,
     what I did. The subtitle above stays a one-line deck. */
  .project-row__description {
    max-width: 58ch;
    color: var(--color-text-muted);
  }

  .project-row__keywords {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
