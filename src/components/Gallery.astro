---
/**
 * Gallery — horizontal scroll-snap strip of captioned figures. Pure CSS
 * (overflow + scroll-snap): keyboard and touch scrolling come from the
 * browser, no JS is shipped. Deliberately not an auto-rotating carousel —
 * see the anti-patterns in Gallery.metadata.json.
 */
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Figure from "./Figure.astro";

interface GalleryImage {
  image: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  /** Accessible name of the scroll region. */
  label: string;
  images: GalleryImage[];
  /**
   * Filmstrip: uniform height, natural widths — an editorial photo band
   * (use inside a full-bleed wrapper). Default: uniform slide width.
   */
  filmstrip?: boolean;
}

const { label, images, filmstrip = false } = Astro.props;
---

<div
  class={`gallery${filmstrip ? " gallery--filmstrip" : ""}`}
  role="region"
  aria-label={label}
>
  <ul class="gallery__track" tabindex="0">
    {
      images.map((item) => (
        <li class="gallery__item">
          <Figure caption={item.caption}>
            <Image
              src={item.image}
              alt={item.alt}
              widths={[480, 800, 1200]}
              sizes="(min-width: 60rem) 48rem, 85vw"
            />
          </Figure>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .gallery {
    inline-size: 100%;
  }

  .gallery__track {
    display: grid;
    grid-auto-flow: column;
    /* 85% leaves the next slide peeking in — the scroll affordance. */
    grid-auto-columns: 85%;
    gap: var(--gallery-gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    /* Smooth keyboard scrolling; the global reduced-motion rule resets it. */
    scroll-behavior: smooth;
    list-style: none;
    margin: 0;
    padding: 0;
    padding-block-end: var(--gallery-track-padding-block-end);
  }

  .gallery__item {
    scroll-snap-align: start;
  }

  /* Filmstrip variant: slides take their natural width at a shared height —
     mixed portrait/landscape photos form one calm band. */
  .gallery--filmstrip .gallery__track {
    grid-auto-columns: max-content;
    /* Browsing, not paging: only settle on an edge when already close —
       mandatory would yank mid-scroll with these mixed widths. */
    scroll-snap-type: x proximity;
  }

  .gallery--filmstrip .gallery__item {
    max-inline-size: 85vw;
  }

  .gallery--filmstrip .gallery__item :global(img) {
    inline-size: auto;
    max-inline-size: 100%;
    block-size: clamp(16rem, 40vh, 24rem);
    object-fit: cover;
  }

  /* The caption must not widen the column: zero intrinsic width, then
     stretch to the image — text wraps exactly at the photo's edge. */
  .gallery--filmstrip .gallery__item :global(figcaption) {
    inline-size: 0;
    min-inline-size: 100%;
  }
</style>
