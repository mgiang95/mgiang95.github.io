---
/**
 * ProjectCard — teaser for a featured case study (home + projects index).
 * Builds on the Card surface; consumes card.* and semantic tokens only.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Badge from "./Badge.astro";

interface Props {
  project: CollectionEntry<"projects">;
  /** 1-based position in the list, rendered as a mono ordinal ("01"). */
  index?: number;
}

const { project, index } = Astro.props;
const { title, subtitle, period, keywords, heroImage } = project.data;
const ordinal =
  typeof index === "number" ? String(index).padStart(2, "0") : undefined;
---

<article class="project-card">
  <a class="project-card__link" href={`/projects/${project.id}`}>
    {
      heroImage && (
        <Image
          class="project-card__image"
          src={heroImage}
          alt=""
          widths={[480, 800, 1200]}
          sizes="(min-width: 60rem) 33vw, 100vw"
        />
      )
    }
    <div class="project-card__body">
      <header class="project-card__header">
        <h3 class="project-card__title">
          {ordinal && <span class="project-card__index" aria-hidden="true">{ordinal}</span>}
          {title}
        </h3>
        <p class="project-card__period">{period}</p>
      </header>
      <p class="project-card__subtitle">{subtitle}</p>
      <ul class="project-card__keywords" aria-label="Key areas">
        {
          keywords.map((keyword) => (
            <li>
              <Badge>{keyword}</Badge>
            </li>
          ))
        }
      </ul>
    </div>
  </a>
</article>

<style>
  .project-card {
    background: var(--card-background);
    border: 1px solid var(--card-border);
    /* Top edge doubles as the hover accent — the poster motif. */
    border-block-start: 2px solid var(--card-border);
    border-radius: var(--card-radius);
    overflow: hidden;
    transition: border-color var(--motion-state-duration)
      var(--motion-state-easing);
  }

  .project-card:hover {
    border-color: var(--card-border-hover);
    border-block-start-color: var(--card-edge-hover);
  }

  .project-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .project-card__link:hover .project-card__title {
    color: var(--color-interactive-hover);
  }

  .project-card__index {
    display: block;
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    color: var(--color-text-muted);
    margin-block-end: var(--space-stack-xs);
  }

  .project-card__image {
    inline-size: 100%;
    block-size: auto;
    border-block-end: 1px solid var(--card-border);
  }

  .project-card__body {
    display: grid;
    gap: var(--card-gap);
    padding: var(--card-padding);
  }

  .project-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-inline-md);
  }

  .project-card__title {
    font-size: var(--typography-heading-sm-size);
  }

  .project-card__period {
    color: var(--color-text-muted);
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    white-space: nowrap;
  }

  .project-card__subtitle {
    color: var(--color-text-secondary);
  }

  .project-card__keywords {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
