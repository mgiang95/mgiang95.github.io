---
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineItem from "../components/TimelineItem.astro";
import Gallery from "../components/Gallery.astro";
import { inlineMarkdown } from "../lib/inline-md";
import activities from "../data/activities.json";

const intro = await getEntry("about", "intro");
if (!intro) throw new Error("about/intro.md missing");
const { Content: Bio } = await render(intro);

const timeline = (await getCollection("timeline")).sort(
  (a, b) => a.data.order - b.data.order,
);

const certifications = (await getCollection("certifications")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);

// Reading log: newest shelf first, alphabetical within a year.
const books = (await getCollection("books")).sort(
  (a, b) =>
    b.data.year - a.data.year || a.data.title.localeCompare(b.data.title),
);
const shelfYears = [...new Set(books.map((book) => book.data.year))];

// Personal photos: resolve the activity file names against the assets.
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/about/img-*.jpg",
  { eager: true },
);
const offScreen = activities.activities.map((entry) => ({
  image: photoModules[`../assets/about/${entry.image}`].default,
  alt: entry.alt,
  caption: entry.caption,
}));

/** "2022-09" -> "Sep 2022" for display. */
function formatDate(date: string): string {
  const [year, month] = date.split("-").map(Number);
  return new Date(year, month - 1).toLocaleString("en", {
    month: "short",
    year: "numeric",
  });
}

// UTC: yaml dates parse as UTC midnight, so a time zone west of UTC would
// otherwise pull the first of a month back into the previous one.
function formatPeriod(start: Date, end: Date | null): string {
  const fmt = (d: Date) =>
    d.toLocaleString("en", { timeZone: "UTC", month: "short", year: "numeric" });
  return end ? `${fmt(start)} – ${fmt(end)}` : `since ${fmt(start)}`;
}
---

<BaseLayout
  title="About"
  description="About Michael Giang — Design System Engineer and UX Designer in Zurich: bio, changelog-style CV and certifications."
>
  <section class="about__intro">
    <div class="about__bio">
      <h1>About</h1>
      <p class="annotations" aria-hidden="true">
        <code>{intro.data.based}</code>
        <code>{timeline.length} stations</code>
        <code>{certifications.length} certifications &amp; awards</code>
        <code>{books.length} books logged</code>
      </p>
      <p class="about__tagline">{intro.data.tagline}</p>
      <div class="prose">
        <Bio />
      </div>
    </div>
    {
      intro.data.profileImage && (
        <figure class="about__portrait-figure">
          <Image
            class="about__portrait"
            src={intro.data.profileImage}
            alt={`Portrait of ${intro.data.name}`}
            widths={[320, 640]}
            sizes="(min-width: 60rem) 20rem, 60vw"
          />
          <figcaption class="about__portrait-note">
            {intro.data.name} · {intro.data.based}
          </figcaption>
        </figure>
      )
    }
  </section>

  <section class="about__journey" aria-labelledby="journey-heading">
    <h2 id="journey-heading">Journey</h2>
    <p class="about__note">
      Work and education on one line — the marker tells them apart: filled
      squares are roles, outlined squares are studies.
    </p>
    <fieldset class="about__filter">
      <legend class="about__filter-legend">Show</legend>
      <label class="about__filter-option">
        <input
          type="radio"
          name="timeline-filter"
          id="timeline-filter-all"
          checked
        />
        All
      </label>
      <label class="about__filter-option about__filter-option--work">
        <input type="radio" name="timeline-filter" id="timeline-filter-work" />
        Work
      </label>
      <label class="about__filter-option about__filter-option--education">
        <input
          type="radio"
          name="timeline-filter"
          id="timeline-filter-education"
        />
        Education
      </label>
    </fieldset>
    <ul class="about__timeline">
      {
        timeline.map((entry) => (
          <TimelineItem
            title={entry.data.title}
            meta={`${entry.data.institution} (${entry.data.location})`}
            period={formatPeriod(entry.data.dateStart, entry.data.dateEnd)}
            type={entry.data.type}
          >
            {entry.data.highlights.length > 0 && (
              <ul class="about__highlights">
                {entry.data.highlights.map((highlight) => (
                  <li set:html={inlineMarkdown(highlight)} />
                ))}
              </ul>
            )}
          </TimelineItem>
        ))
      }
    </ul>
  </section>

  <section class="about__certs" aria-labelledby="certs-heading">
    <h2 id="certs-heading">Certifications, scholarships &amp; awards</h2>
    <div class="about__certs-scroll">
      <table class="about__certs-table">
        <thead>
          <tr>
            <th scope="col">Date</th>
            <th scope="col">Title</th>
            <th scope="col">Issuer</th>
          </tr>
        </thead>
        <tbody>
          {
            certifications.map(({ data }) => (
              <tr>
                <td class="about__certs-date">{formatDate(data.date)}</td>
                <td>
                  <p class="about__certs-title">
                    {data.url ? <a href={data.url}>{data.title}</a> : data.title}
                  </p>
                  {data.description && (
                    <p class="about__certs-description">{data.description}</p>
                  )}
                </td>
                <td class="about__certs-issuer">{data.issuer}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="about__offscreen" aria-labelledby="offscreen-heading">
    <h2 id="offscreen-heading">Off screen</h2>
    <p class="about__note">{activities.introduction}</p>
    <div class="about__offscreen-band">
      <Gallery label="Personal photos" images={offScreen} filmstrip />
    </div>
  </section>

  <section class="about__reading" aria-labelledby="reading-heading">
    <h2 id="reading-heading">Reading</h2>
    <p class="about__note">
      An ongoing log, one entry per book — the year is when I read it, not
      when it was published.
    </p>
    {
      shelfYears.map((year) => (
        <div class="about__shelf">
          <h3 class="about__shelf-year">{year}</h3>
          <ul class="about__shelf-list">
            {books
              .filter((book) => book.data.year === year)
              .map(({ data }) => (
                <li class="about__book">
                  {data.cover ? (
                    <Image
                      class="about__book-cover"
                      src={data.cover}
                      alt={`Cover: ${data.title}`}
                      widths={[160, 320]}
                      sizes="7rem"
                    />
                  ) : (
                    <span
                      class="about__book-cover about__book-cover--generated"
                      aria-hidden="true"
                    >
                      {data.title}
                    </span>
                  )}
                  <div class="about__book-text">
                    <p class="about__book-title">{data.title}</p>
                    <p class="about__book-author">{data.author}</p>
                    {data.takeaway && (
                      <p class="about__book-takeaway">{data.takeaway}</p>
                    )}
                  </div>
                </li>
              ))}
          </ul>
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .about__intro {
    display: grid;
    gap: var(--space-stack-lg);
    align-items: start;
    padding-block-end: var(--space-stack-xl);
  }

  @media (min-width: 60rem) {
    .about__intro {
      grid-template-columns: 1fr 20rem;
      column-gap: var(--space-inline-xl);
    }
  }

  .about__bio {
    display: grid;
    gap: var(--space-stack-md);
    max-width: 65ch;
  }

  /* The tagline is the page's poster statement, not a subtitle. */
  .about__tagline {
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-bold);
    font-size: var(--typography-heading-lg-size);
    line-height: var(--typography-heading-lg-line-height);
    max-width: 24ch;
  }

  .about__portrait-figure {
    display: grid;
    gap: var(--space-stack-xs);
    margin: 0;
  }

  .about__portrait {
    inline-size: 100%;
    block-size: auto;
    border: 1px solid var(--color-border-default);
    /* The poster's accent edge, echoed on the portrait (after the
       shorthand — it would reset the longhand otherwise). */
    border-block-start: 2px solid var(--color-surface-accent);
  }

  .about__portrait-note {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
  }

  .about__journey,
  .about__certs {
    margin-block-start: var(--space-stack-xl);
  }

  .about__note {
    margin-block: var(--space-stack-xs) var(--space-stack-md);
    max-width: 65ch;
    color: var(--color-text-secondary);
  }

  .about__filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-inline-md);
    margin: 0 0 var(--space-stack-lg);
    padding: 0;
    border: none;
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
  }

  .about__filter-legend {
    padding: 0;
    margin-inline-end: var(--space-inline-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .about__filter-option {
    display: inline-flex;
    align-items: center;
    gap: var(--space-inline-xs);
  }

  .about__filter-option input {
    accent-color: var(--color-interactive-default);
  }

  /* Marker legend: the same squares the timeline uses. */
  .about__filter-option--work::after,
  .about__filter-option--education::after {
    content: "";
    display: inline-block;
    inline-size: 0.6em;
    block-size: 0.6em;
  }

  .about__filter-option--work::after {
    background: var(--color-surface-accent);
  }

  .about__filter-option--education::after {
    border: 2px solid var(--color-surface-accent);
  }

  /* CSS-only filter: radios + :has(), no JavaScript involved. */
  .about__journey:has(#timeline-filter-work:checked)
    :global(.timeline-item--education),
  .about__journey:has(#timeline-filter-education:checked)
    :global(.timeline-item--work) {
    display: none;
  }

  .about__timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 65ch;
  }

  .about__highlights {
    padding-inline-start: var(--space-inset-lg);
    display: grid;
    gap: var(--space-stack-xs);
  }

  /* Certifications as a Swiss index table — same pattern as the project
     index and the token docs. */
  .about__certs-scroll {
    overflow-x: auto;
    margin-block-start: var(--space-stack-md);
  }

  .about__certs-table {
    border-collapse: collapse;
    inline-size: 100%;
  }

  .about__certs-table th {
    text-align: start;
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    color: var(--color-text-secondary);
  }

  .about__certs-table th,
  .about__certs-table td {
    padding: var(--space-inset-xs) var(--space-inline-lg) var(--space-inset-xs)
      0;
    border-block-end: 1px solid var(--color-border-default);
    vertical-align: top;
  }

  .about__certs-date {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .about__certs-title {
    font-weight: var(--font-weight-medium);
  }

  .about__certs-description {
    margin-block-start: var(--space-stack-xs);
    max-width: 45ch;
    font-size: var(--font-size-200);
    color: var(--color-text-secondary);
  }

  .about__certs-issuer {
    color: var(--color-text-secondary);
  }

  /* Reading log: the year is the shelf — a large mono numeral over a
     hairline, entries as cover + text rows. */
  .about__reading,
  .about__offscreen {
    margin-block-start: var(--space-stack-xl);
  }

  /* Off-screen photo band: escapes the column and runs to the viewport
     edge — the poster's rule-break, reused as the page's visual pause.
     The first slide stays on the text axis. */
  .about__offscreen-band {
    margin-block-start: var(--space-stack-md);
    margin-inline: calc(50% - 50vw);
    padding-inline-start: calc(max(0px, 50vw - 36rem) + var(--space-inset-lg));
  }

  .about__shelf {
    margin-block-start: var(--space-stack-lg);
  }

  .about__shelf-year {
    font-family: var(--typography-label-family);
    /* Fluid display size — the shelves carry the page's large numerals. */
    font-size: var(--font-size-800);
    font-weight: var(--typography-label-weight);
    line-height: var(--font-line-height-tight);
    color: var(--color-text-muted);
    padding-block-end: var(--space-stack-xs);
    border-block-end: 1px solid var(--color-border-default);
  }

  .about__shelf-list {
    list-style: none;
    margin: var(--space-stack-md) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-stack-lg) var(--space-inline-xl);
  }

  @media (min-width: 60rem) {
    .about__shelf-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .about__book {
    display: grid;
    grid-template-columns: 7rem 1fr;
    column-gap: var(--space-inline-md);
    align-items: start;
  }

  .about__book-cover {
    inline-size: 100%;
    block-size: auto;
    border: 1px solid var(--color-border-default);
  }

  /* Generated cover for books without an image: the poster as fallback. */
  .about__book-cover--generated {
    display: grid;
    align-content: end;
    aspect-ratio: 2 / 3;
    padding: var(--space-inset-sm);
    background: var(--color-surface-accent);
    color: var(--color-text-on-accent);
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-bold);
    line-height: var(--font-line-height-tight);
  }

  .about__book-text {
    display: grid;
    gap: var(--space-stack-xs);
    align-content: start;
  }

  .about__book-title {
    font-weight: var(--font-weight-medium);
  }

  .about__book-author {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
  }

  .about__book-takeaway {
    font-size: var(--font-size-200);
    color: var(--color-text-secondary);
    max-width: 40ch;
  }
</style>
