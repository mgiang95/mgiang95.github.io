---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemePanel from "../components/ThemePanel.tsx";
import ProjectRow from "../components/ProjectRow.astro";
import Cloud from "../components/Cloud.astro";
import { ACCENT_RAMP_STEPS } from "../lib/tokens";
import { tokenTiers } from "../lib/token-tiers";
import contact from "../data/contact.json";

const tiers = tokenTiers();

const featured = (
  await getCollection("projects", ({ data }) => data.featured)
).sort((a, b) => a.data.order - b.data.order);

const more = (
  await getCollection("projects", ({ data }) => !data.featured && !data.parent)
).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Design System Engineer"
  description="Portfolio of Michael Giang, Design System Engineer and UX Designer in Zurich. This site runs on a live design token pipeline — adjust hue, color scheme and density yourself."
>
  <section class="poster" aria-labelledby="poster-headline">
    <p class="poster__kicker">Multidisciplinary designer based in Zurich, CH</p>
    <h1 class="poster__headline" id="poster-headline">
      Michael Giang <br /> UX Designer
    </h1>

    <div class="poster__annotations">
      <p class="poster__description">
        I make complex problems manageable through accessible abstractions. I
        like to think in sustainable systems and to develop ideas by building
        them as prototypes, models or notation.
      </p>
      <p class="poster__description">
        This portfolio runs on the same foundation and principles. Every color,
        space and size on this page resolves from design tokens while keeping
        accessibility in mind. Feel free to change them and explore my work.
      </p>
    </div>

    <div class="poster__canvas" data-hue-scrub>
      <div class="poster__field">
        <Cloud class="poster__cloud" />
        <p class="poster__claim">Drag to shift the hue.</p>
        <p class="poster__facts" aria-hidden="true">
          <code>--hue: <span data-hue-readout>220</span></code>
          <code>color.accent.&lbrace;50 … 950&rbrace;</code>
          <code data-contrast-readout>contrast ≥ 4.5:1 for every hue</code>
        </p>
        <code class="poster__field-label" aria-hidden="true">
          --color-surface-accent
        </code>
      </div>
      <div class="poster__ramp" aria-hidden="true">
        {
          ACCENT_RAMP_STEPS.map((step) => (
            <span
              class="poster__step"
              style={`background: var(--color-accent-${step})`}
            />
          ))
        }
      </div>
    </div>

    <div class="poster__controls">
      <div class="poster__instruments">
        <ThemePanel client:idle variant="strip" />
        <token-inspector
          compact
          label="inspect the tokens"
          class="poster__inspect"
          tiers={JSON.stringify(tiers)}></token-inspector>
      </div>
      <a class="poster__how" href="/system">how this is built →</a>
    </div>
  </section>

  <section class="work" aria-labelledby="work-heading">
    <h2 id="work-heading">Selected work</h2>
    <div class="work__rows">
      {featured.map((project) => <ProjectRow project={project} />)}
    </div>

    <a class="work__system" href="/system">
      <p class="work__system-meta" aria-hidden="true">
        Portfolio as Case Study
      </p>
      <h3 class="work__system-title">
        How Components and Tokens are wired on this Site
      </h3>
      <p class="work__system-subtitle">
        Primitives, semantic tokens and components run through one pipeline.
        Every build validates the hierarchy and proves the contrast at every
        hue.
      </p>
    </a>
  </section>

  <section class="more" aria-labelledby="more-heading">
    <h2 id="more-heading">More projects</h2>
    <div class="more__scroll">
      <table class="more__table">
        <thead>
          <tr>
            <th scope="col">Period</th>
            <th scope="col">Project</th>
            <th scope="col">Focus</th>
          </tr>
        </thead>
        <tbody>
          {
            more.map((entry) => (
              <tr>
                <td class="more__period">{entry.data.period}</td>
                <td class="more__title">
                  <a href={`/projects/${entry.id}`}>{entry.data.title}</a>
                </td>
                <td class="more__focus">{entry.data.keywords.join(", ")}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="outro" aria-labelledby="outro-heading">
    <div class="outro__field">
      <Cloud class="outro__cloud" />
      <h2 class="outro__heading" id="outro-heading">
        Interested in connecting?
      </h2>
      <p class="outro__lead">
        I'd love to hear from you! Whether you have questions, or just feel like
        saying hi, don't hesitate to reach out.
      </p>
      <div class="outro__actions">
        <a
          class="outro__email"
          href={`mailto:${contact.email}`}
          data-copy-email={contact.email}
        >
          <span data-contact-label>{contact.email}</span>
        </a>
        <a class="outro__link" href={contact.github}>GitHub</a>
        <a class="outro__link" href={contact.linkedin}>LinkedIn</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { worstPair, currentTheme } from "../lib/live-contrast";
  import { dispatchHueChange, onHueChange } from "../lib/theme-events";

  // Live contrast badge in the annotations: the static claim becomes the
  // computed proof, following hue drags and scheme switches. The no-JS
  // markup keeps the static (and still true) guarantee.
  const contrastReadout = document.querySelector("[data-contrast-readout]");
  function updateContrast(hueOverride?: number) {
    if (!contrastReadout) return;
    const hue =
      hueOverride ??
      (Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue("--hue"),
      ) ||
        220);
    const worst = worstPair(currentTheme(), hue);
    contrastReadout.textContent = `contrast ${worst.ratio.toFixed(2)}:1 @ worst pair · AA ${
      worst.margin >= 1 ? "✓" : "✗"
    }`;
  }
  updateContrast();
  // data-theme is applied by a React effect AFTER the pref-change event
  // fires — observe the attribute itself instead of racing the event.
  new MutationObserver(() => updateContrast()).observe(
    document.documentElement,
    { attributes: true, attributeFilter: ["data-theme"] },
  );
  matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () =>
    updateContrast(),
  );

  // Hue scrubbing on the poster canvas: horizontal dragging maps the full
  // canvas width to 360 degrees. Pointer-only enhancement — the accessible
  // hue control remains the ThemePanel in the nav popover; all instances
  // stay in sync via the theme-events contract (dispatched on user input
  // only, so no loop).
  const canvas = document.querySelector<HTMLElement>("[data-hue-scrub]");
  const readout = document.querySelector("[data-hue-readout]");

  if (canvas) {
    const html = document.documentElement;
    const currentHue = () =>
      Number.parseFloat(getComputedStyle(html).getPropertyValue("--hue")) ||
      220;

    if (readout) readout.textContent = String(Math.round(currentHue()));

    let dragging = false;
    let startX = 0;
    let startHue = 220;
    let saveTimer = 0;

    const apply = (hue: number) => {
      html.style.setProperty("--hue", String(hue));
      if (readout) readout.textContent = String(hue);
      dispatchHueChange(hue);
      // Persist debounced — same key and cadence as the ThemePanel.
      window.clearTimeout(saveTimer);
      saveTimer = window.setTimeout(() => {
        try {
          localStorage.setItem("pref-hue", String(hue));
        } catch {
          /* storage unavailable */
        }
      }, 150);
    };

    canvas.addEventListener("pointerdown", (event) => {
      dragging = true;
      startX = event.clientX;
      startHue = currentHue();
      try {
        canvas.setPointerCapture(event.pointerId);
      } catch {
        /* capture unavailable — dragging still works inside the canvas */
      }
    });

    canvas.addEventListener("pointermove", (event) => {
      if (!dragging) return;
      const delta = ((event.clientX - startX) / canvas.clientWidth) * 360;
      const hue = Math.round((((startHue + delta) % 360) + 360) % 360);
      apply(hue);
    });

    const endDrag = () => {
      dragging = false;
    };
    canvas.addEventListener("pointerup", endDrag);
    canvas.addEventListener("pointercancel", endDrag);

    // Keep the annotation readouts live when the panel slider is the
    // source. The payload carries the hue — ordering rule in theme-events.
    onHueChange((value) => {
      if (readout) readout.textContent = String(Math.round(value));
      updateContrast(value);
    });
  }
</script>

<style>
  .poster {
    display: grid;
    gap: var(--space-stack-md);
    padding-block: var(--space-stack-lg) var(--space-stack-xl);
  }

  /* Who/what/where in second one — before the thesis. */
  .poster__kicker {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  .poster__headline {
    font-size: var(--font-size-900);
    /* Archivo's width axis, put to work: expanded display cut for the
       poster — the typeface is parametric like everything else here. */
    font-stretch: 115%;
    max-width: 14ch;
  }

  .poster__description {
    max-width: 65ch;
    font-size: var(--typography-lead-size);
    color: var(--color-text-secondary);
  }

  .poster__annotations {
    display: grid;
    gap: var(--space-stack-sm);
  }

  /* Live readouts sit inside the field they describe — the numbers change
     under the same drag that changes the color. */
  .poster__facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-lg);
    font-size: var(--typography-label-size);
    /* Held to the text column so the readouts stop running into the half of
       the field the mark occupies — the line wraps instead of colliding. */
    max-inline-size: 40ch;
  }

  /* Pushed to the trailing edge of the instrument row — control typography,
     like the switches. The padding repeats the caption offset the switch
     groups carry (their caption is lifted out of flow into padding of this
     exact height), so with the row aligned at flex-start the link's baseline
     lands on the scheme switch row, not on the smaller caption line. */
  .poster__how {
    font-family: var(--typography-control-family);
    font-size: var(--typography-control-size);
    line-height: var(--typography-control-line-height);
    margin-inline-start: auto;
    padding-block-start: calc(
      var(--typography-label-size) * var(--typography-label-line-height)
    );
  }

  /* Full-bleed rule-break: the poster escapes the centered content column
     and runs edge to edge — the one deliberate grid violation (SPEC §7). */
  .poster__canvas {
    margin-inline: calc(50% - 50vw);
    margin-block-start: var(--space-stack-md);
    display: grid;
    min-block-size: clamp(18rem, 55svh, 34rem);
    cursor: ew-resize;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  @media (min-width: 60rem) {
    .poster__canvas {
      grid-template-columns: 1fr clamp(6rem, 14vw, 11rem);
    }
  }

  .poster__field {
    position: relative;
    /* The mark is cropped by this edge — the crop is the composition. */
    overflow: hidden;
    display: grid;
    align-content: center;
    gap: var(--space-stack-md);
    background: var(--color-surface-accent);
    color: var(--color-text-on-accent);
    padding-block: var(--space-inset-xl);
    /* Re-align the inner text with the exact text axis of the 72rem
       content column (incl. its inset). */
    padding-inline: calc(max(0px, 50vw - 36rem) + var(--space-inset-lg));
  }

  /* The brand mark, printed into the empty half of the field and running off
     its end and bottom edge. It stays clear of the text column: the contrast
     proof covers text on the accent surface, not text on a shape laid over
     it, and a claim about contrast is not something to leave to chance. */
  .poster__cloud {
    position: absolute;
    z-index: 0;
    /* The mark owns the empty half of the field: it runs off the end edge and
       out of the bottom, and it scales with the viewport so the gap to the
       text column holds at every width above the breakpoint. */
    inset-inline-end: -6vw;
    inset-block-start: 20%;
    inline-size: clamp(24rem, 48vw, 60rem);
    aspect-ratio: 1668 / 1091;
  }

  /* The mark needs a genuinely empty half to print into. Below this width the
     readouts and the mark would fight over the same space (measured: they
     collide from ~61rem down), so the mark steps aside instead of crowding
     the text. It is decoration — it yields first. */
  @media (max-width: 68rem) {
    .poster__cloud {
      display: none;
    }
  }

  .poster__claim,
  .poster__facts {
    position: relative;
    z-index: 1;
  }

  .poster__claim {
    font-family: var(--font-family-display);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-700);
    line-height: var(--font-line-height-tight);
    max-width: 24ch;
  }

  /* A hover lens is pointless on touch; narrow screens lose it like the
     nav square does. */
  @media (max-width: 30rem) {
    .poster__inspect {
      display: none;
    }
  }

  .poster__field-label {
    position: absolute;
    inset-block-start: var(--space-inset-md);
    inset-inline-end: var(--space-inset-md);
    font-size: var(--typography-label-size);
  }

  .poster__ramp {
    display: grid;
    grid-auto-flow: row;
    block-size: var(--space-stack-xl);
  }

  @media (min-width: 60rem) {
    .poster__ramp {
      block-size: auto;
    }
  }

  @media (max-width: 59.9rem) {
    .poster__ramp {
      grid-auto-flow: column;
    }
  }

  .poster__step {
    display: block;
  }

  /* The block at the poster's edge, split by function: the instruments that
     act on the system (scheme, density, token lens) stack as one column on
     the left; the link out is a signpost, not an instrument, and sits alone
     at the top right — hue is the canvas, the readouts sit in the field. */
  .poster__controls {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    column-gap: var(--space-inline-xxl);
    row-gap: var(--space-stack-xs);
    padding-block: var(--space-inset-sm);
  }

  /* One rhythm for the whole column: this gap matches the strip's internal
     gap between its switch groups, so scheme, density and the lens read as
     three rows of the same instrument. */
  .poster__instruments {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    row-gap: var(--space-stack-sm);
  }

  .poster__inspect {
    font-size: var(--typography-control-size);
    line-height: var(--typography-control-line-height);
    color: var(--color-text-secondary);
  }

  .poster__lead {
    max-width: 65ch;
    margin-block-start: var(--space-stack-sm);
    font-size: var(--typography-lead-size);
    color: var(--color-text-secondary);
  }

  .work {
    padding-block: var(--space-stack-xl) var(--space-stack-lg);
  }

  .work__rows {
    margin-block-start: var(--space-stack-md);
  }

  .work__system {
    display: grid;
    gap: var(--space-stack-xs);
    justify-items: start;
    padding-block: var(--space-stack-md);
    border-block-end: 1px solid var(--color-border-default);
    color: inherit;
    text-decoration: none;
  }

  .work__system-meta {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .work__system-title {
    font-size: var(--typography-heading-sm-size);
    transition: color var(--motion-state-duration) var(--motion-state-easing);
  }

  .work__system:hover .work__system-title {
    color: var(--color-interactive-hover);
  }

  .work__system-subtitle {
    max-width: 55ch;
    color: var(--color-text-secondary);
  }

  .more {
    padding-block: var(--space-stack-lg) var(--space-stack-xl);
  }

  .more__scroll {
    overflow-x: auto;
    margin-block-start: var(--space-stack-md);
  }

  .more__table {
    border-collapse: collapse;
    inline-size: 100%;
  }

  .more__table th {
    text-align: start;
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    color: var(--color-text-secondary);
  }

  .more__table th,
  .more__table td {
    padding: var(--space-inset-xs) var(--space-inline-lg) var(--space-inset-xs)
      0;
    border-block-end: 1px solid var(--color-border-default);
    vertical-align: top;
  }

  .more__period {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .more__focus {
    color: var(--color-text-secondary);
  }

  /* Outro: the poster's accent field returns as the closing bookend. */
  .outro {
    margin-block-start: var(--space-stack-xl);
  }

  .outro__field {
    position: relative;
    overflow: hidden;
    margin-inline: calc(50% - 50vw);
    padding-block: var(--space-stack-xl);
    padding-inline: calc(max(0px, 50vw - 36rem) + var(--space-inset-lg));
    background: var(--color-surface-accent);
    color: var(--color-text-on-accent);
    display: grid;
    gap: var(--space-stack-lg);
    justify-items: start;
  }

  /* The bookend: the same mark, upright, cropped against the top edge instead
     of the bottom — the poster's shape returns from the other side. */
  .outro__cloud {
    position: absolute;
    z-index: 0;
    inset-inline-end: -4vw;
    inset-block-start: -22%;
    inline-size: clamp(18rem, 40vw, 44rem);
    aspect-ratio: 1668 / 1091;
  }

  @media (max-width: 60rem) {
    .outro__cloud {
      display: none;
    }
  }

  .outro__heading,
  .outro__actions {
    position: relative;
    z-index: 1;
  }

  .outro__heading {
    font-size: var(--font-size-800);
    font-stretch: 115%;
    line-height: var(--font-line-height-tight);
    max-width: 24ch;
  }

  .outro__lead {
    max-width: 65ch;
  }

  .outro__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-inline-lg);
  }

  .outro__email {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    padding: var(--space-inset-xs) var(--space-inset-md);
    border: 1px solid var(--color-text-on-accent);
    color: var(--color-text-on-accent);
    text-decoration: none;
    transition:
      background-color var(--motion-state-duration) var(--motion-state-easing),
      color var(--motion-state-duration) var(--motion-state-easing);
  }

  .outro__email:hover {
    background: var(--color-text-on-accent);
    color: var(--color-surface-accent);
  }

  .outro__link {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-on-accent);
  }

  .outro__link:hover {
    color: var(--color-text-on-accent);
  }
</style>
