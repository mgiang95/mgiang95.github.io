---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemePanel from "../components/ThemePanel.tsx";
---

<BaseLayout
  title="Design System Engineer"
  description="Portfolio of Michael Giang, Design System Engineer and UX Designer in Zurich. This site runs on a live design token pipeline — adjust hue, color scheme and density yourself."
>
  <section class="hero">
    <div class="hero__copy">
      <h1 class="hero__headline">This site is a running design system.</h1>
      <p class="hero__lead">
        I'm Michael Giang, a Design System Engineer and UX Designer based in
        Zurich. Everything here resolves from design tokens — try it: change
        hue, scheme and density. Contrast stays AA by construction.
      </p>
    </div>
    <div class="hero__panel">
      <ThemePanel client:idle />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: var(--space-stack-lg);
    padding-block: var(--space-stack-xl);
    align-items: start;
  }

  @media (min-width: 60rem) {
    .hero {
      grid-template-columns: 3fr 2fr;
      column-gap: var(--space-inline-xl);
    }
  }

  .hero__copy {
    display: grid;
    gap: var(--space-stack-lg);
  }

  .hero__headline {
    max-width: 20ch;
  }

  .hero__lead {
    max-width: 55ch;
    font-size: var(--font-size-400);
    color: var(--color-text-secondary);
  }
</style>
