---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import TimelineItem from "../components/TimelineItem.astro";
import Accordion from "../components/Accordion.astro";
import Figure from "../components/Figure.astro";
import Gallery from "../components/Gallery.astro";
import TokenTable from "../components/TokenTable.astro";
import ColorRamp from "../components/ColorRamp.astro";
import figureDemoImage from "../assets/projects/BNI_DS-design_system_components.jpg";
import galleryDemoHierarchy from "../assets/projects/BNI_DS-css-hierarchy.jpg";
import galleryDemoDeprecated from "../assets/projects/BNI_DS-deprecated_mode.jpg";
import galleryDemoAudit from "../assets/projects/BNI_DS-layout_inconsistencies.jpg";
import { flattenTokens } from "../lib/tokens";
import { tokenTiers } from "../lib/token-tiers";
import primitiveColors from "../../tokens/primitives/color.tokens.json";
import semanticColorsLight from "../../tokens/semantic/color-light.tokens.json";
import semanticSpace from "../../tokens/semantic/space-normal.tokens.json";
import semanticShape from "../../tokens/semantic/shape.tokens.json";
import semanticTypography from "../../tokens/semantic/typography.tokens.json";
import semanticMotion from "../../tokens/semantic/motion.tokens.json";
import buttonTokens from "../../tokens/component/button.tokens.json";
import cardTokens from "../../tokens/component/card.tokens.json";
import badgeTokens from "../../tokens/component/badge.tokens.json";
import timelineTokens from "../../tokens/component/timeline.tokens.json";
import themePanelTokens from "../../tokens/component/theme-panel.tokens.json";
import tokenInspectorTokens from "../../tokens/component/token-inspector.tokens.json";
import accordionTokens from "../../tokens/component/accordion.tokens.json";
import figureTokens from "../../tokens/component/figure.tokens.json";
import galleryTokens from "../../tokens/component/gallery.tokens.json";
import ThemePanel from "../components/ThemePanel.tsx";
import ComponentDoc from "../components/ComponentDoc.astro";
import buttonMeta from "../components/Button.metadata.json";
import badgeMeta from "../components/Badge.metadata.json";
import cardMeta from "../components/Card.metadata.json";
import timelineMeta from "../components/TimelineItem.metadata.json";
import themePanelMeta from "../components/ThemePanel.metadata.json";
import tokenInspectorMeta from "../components/TokenInspector.metadata.json";
import accordionMeta from "../components/Accordion.metadata.json";
import figureMeta from "../components/Figure.metadata.json";
import galleryMeta from "../components/Gallery.metadata.json";

const primitives = flattenTokens(primitiveColors);
const accentRamp = primitives.filter((t) => t.path.startsWith("color.accent."));
const neutralRamp = primitives.filter((t) => t.path.startsWith("color.neutral."));

const semanticColors = flattenTokens(semanticColorsLight);
const semanticSpacing = flattenTokens(semanticSpace);
const semanticOther = [
  ...flattenTokens(semanticShape),
  ...flattenTokens(semanticTypography),
  ...flattenTokens(semanticMotion),
];

// Annotation facts — computed, not written, so they cannot go stale.
const componentCount = Object.keys(
  import.meta.glob("../components/*.metadata.json"),
).length;

// Tier lists for the TokenInspector — globbed from the same DTCG sources
// as everything else (shared with the instrument bar in BaseLayout).
const tiers = tokenTiers();

const tokenVarCount =
  tiers.primitive.length + tiers.semantic.length + tiers.component.length;
---

<BaseLayout
  title="System"
  description="How this site is built: token architecture, theming mechanics and component docs."
>
  <h1>How this site is built</h1>
  <p class="annotations" aria-hidden="true">
    <code>{componentCount} components</code>
    <code>{tokenVarCount} custom properties</code>
    <code>audit passing</code>
  </p>
  <p class="system__lead">
    Every page you have seen runs on the system documented here. This page
    holds the reasoning — and reference docs generated from the same source
    files the site consumes, so they cannot drift.
  </p>

  <div class="prose system__case">
    <h2>Problem</h2>
    <p>
      Portfolios <em>describe</em> design system work with screenshots — and
      screenshots prove nothing. The craft is in constraints that hold under
      change: contrast that survives any brand color, spacing that adapts
      without breaking rhythm, components that cannot hardcode a value even
      by accident.
    </p>

    <h2>Approach</h2>
    <p>
      Make the system itself the exhibit. Tokens live as DTCG JSON in three
      strict tiers — primitives, semantic, component — and compile to CSS
      custom properties. Visitors change hue, scheme and density at runtime
      and watch every element follow; an auditor and a test suite keep the
      rules from being prose.
    </p>
  </div>

  <section class="system__section" aria-labelledby="decisions-heading">
    <h2 id="decisions-heading">Decisions</h2>
    <ol class="system__decisions">
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">01</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">
            OKLCH with fixed lightness and chroma
          </h3>
          <p>
            All color derives from a single <code>--hue</code>. Contrast is
            driven by lightness, so every text/surface pair is proven against
            WCAG AA for all 360 hues at build time — a failing pair fails the
            build. The badge on the poster runs the same math live.
          </p>
        </div>
      </li>
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">02</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">
            The semantic tier is the only switch
          </h3>
          <p>
            Light/dark and the three density modes are nothing but different
            resolutions of the same semantic tokens. Components never know
            which mode they are in.
          </p>
        </div>
      </li>
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">03</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">Islands, not an app</h3>
          <p>
            Astro keeps content static; JavaScript exists only where behavior
            lives — the theme panel (React) and the token inspector (Lit).
            Without JS the site works fully on its defaults. Three renderers,
            one token contract: custom properties cross the shadow DOM
            boundary on their own.
          </p>
        </div>
      </li>
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">04</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">
            Density moves whitespace, the viewport moves type
          </h3>
          <p>
            <code>data-density</code> resolves spacing tokens to other steps
            of the 4px scale — readability is untouched. Display type is
            fluid via <code>clamp()</code> primitives; body sizes stay fixed.
          </p>
        </div>
      </li>
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">05</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">Motion has meanings, not moods</h3>
          <p>
            Exactly three: state feedback, expand/collapse, and discrete mode
            switches inside a brief page-wide window. The hue slider never
            animates — direct manipulation must not lag behind the pointer.
          </p>
        </div>
      </li>
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">06</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">One grotesque, one mono, one origin</h3>
          <p>
            Archivo carries display and body — its width axis works on the
            poster headline. Fragment Mono, cut from the same Swiss grotesque
            form, speaks wherever the system does: tokens, annotations,
            ordinals. Both self-hosted; this site makes no third-party
            requests.
          </p>
        </div>
      </li>
      <li class="system__decision">
        <span class="system__decision-index" aria-hidden="true">07</span>
        <div class="system__decision-body">
          <h3 class="system__decision-title">Invariants are enforced, not promised</h3>
          <p>
            An auditor fails the build on any rule violation, and the checking
            tools are themselves under test. What that means in practice:
            <a href="#ai-heading">Machine-readable by design</a>.
          </p>
        </div>
      </li>
    </ol>
  </section>

  <div class="prose system__case">
    <h2>Outcome</h2>
    <p>
      A portfolio whose central claim is verifiable in the browser instead of
      asserted in prose: drag the hue, flip the scheme, inspect any element —
      nothing breaks, and the numbers under the heading above are computed
      from the same files that style this page.
    </p>
  </div>

  <section class="system__section" aria-labelledby="tokens-heading">
    <h2 id="tokens-heading">Tokens</h2>

    <h3>Color primitives</h3>
    <p class="system__note">
      OKLCH ramps with fixed lightness/chroma steps; the hue comes from a
      single <code>--hue</code> custom property. Every text/surface pair is
      contrast-proven for all 360 hues on every build.
    </p>
    <div class="system__ramps">
      <ColorRamp name="color.accent" tokens={accentRamp} />
      <ColorRamp name="color.neutral" tokens={neutralRamp} />
    </div>

    <div class="system__token-reference">
      <Accordion heading="h3" summary="Semantic colors" open>
        <p class="system__note">
          Light mapping shown — the dark theme resolves the same tokens to
          other primitives.
        </p>
        <TokenTable label="Semantic color tokens" tokens={semanticColors} />
      </Accordion>

      <Accordion heading="h3" summary="Semantic spacing">
        <p class="system__note">
          Normal density shown — tight and comfy resolve the same tokens to
          other steps of the 4px scale. Font sizes never change with density.
        </p>
        <TokenTable label="Semantic spacing tokens" tokens={semanticSpacing} />
      </Accordion>

      <Accordion heading="h3" summary="Shape, typography & motion">
        <p class="system__note">
          Motion has exactly three meanings here — state feedback,
          expand/collapse and discrete mode switches. A fourth, the
          scroll-linked figure entrance, is progress-driven and needs no
          duration token. Everything sits behind the global
          <code>prefers-reduced-motion</code> kill switch.
        </p>
        <TokenTable
          label="Shape, typography and motion tokens"
          tokens={semanticOther}
        />
      </Accordion>
    </div>
  </section>

  <section class="system__section" aria-labelledby="components-heading">
    <h2 id="components-heading">Components</h2>
    <p class="system__note">
      Every component ships a co-located <code>*.metadata.json</code> —
      description, use cases, anti-patterns, consumed tokens. The entries
      below are rendered from those files; the same JSON is what AI tooling
      queries before creating or changing a component.
    </p>

    <ComponentDoc meta={buttonMeta} tokens={flattenTokens(buttonTokens)}>
      <Button>Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="ghost">Ghost</Button>
    </ComponentDoc>

    <ComponentDoc meta={badgeMeta} tokens={flattenTokens(badgeTokens)}>
      <Badge>design-tokens</Badge>
      <Badge>oklch</Badge>
      <Badge>astro</Badge>
    </ComponentDoc>

    <ComponentDoc meta={cardMeta} tokens={flattenTokens(cardTokens)}>
      <Card>
        <h4>Card title</h4>
        <p>
          A raised surface for project teasers. Padding, radius and colors
          come from <code>card.*</code> tokens.
        </p>
        <div class="system__demo-row">
          <Badge>token-driven</Badge>
        </div>
      </Card>
    </ComponentDoc>

    <ComponentDoc meta={timelineMeta} tokens={flattenTokens(timelineTokens)}>
      <ul class="system__timeline-demo">
        <TimelineItem
          title="Design System Engineer"
          meta="HIS Engineering AG (Zurich, CH)"
          period="since 2023"
        >
          <p>The square marker is a flat accent zone — move the hue.</p>
        </TimelineItem>
        <TimelineItem
          title="MSc Human-Computer Interaction"
          meta="PLUS &amp; FH Salzburg (Salzburg, AT)"
          period="2020 – 2023"
          type="education"
        />
      </ul>
    </ComponentDoc>

    <ComponentDoc meta={accordionMeta} tokens={flattenTokens(accordionTokens)}>
      <div class="system__accordion-demo">
        <Accordion summary="What is this pattern built on?" open>
          <p>
            Native <code>&lt;details&gt;</code>/<code>&lt;summary&gt;</code> —
            the browser provides keyboard interaction and expanded state.
          </p>
        </Accordion>
        <Accordion summary="Does it need JavaScript?">
          <p>No. This page ships zero JS for it.</p>
        </Accordion>
      </div>
    </ComponentDoc>

    <ComponentDoc meta={figureMeta} tokens={flattenTokens(figureTokens)}>
      <Figure caption="A captioned figure — markdown case studies produce the same markup via rehype-figure.">
        <Image
          src={figureDemoImage}
          alt="Design system component overview from the WinCredit case study"
          widths={[480, 800]}
          sizes="(min-width: 60rem) 40rem, 100vw"
        />
      </Figure>
    </ComponentDoc>

    <ComponentDoc meta={galleryMeta} tokens={flattenTokens(galleryTokens)}>
      <Gallery
        label="Gallery demo — WinCredit design system screenshots"
        images={[
          {
            image: galleryDemoHierarchy,
            alt: "CSS hierarchy of the WinCredit theming architecture",
            caption: "Slides snap as you scroll — keyboard and touch, no JS.",
          },
          {
            image: galleryDemoDeprecated,
            alt: "Deprecated mode of the WinCredit component library",
            caption: "The next slide peeks in as the scroll affordance.",
          },
          {
            image: galleryDemoAudit,
            alt: "Layout inconsistencies found in the WinCredit visual audit",
            caption: "Each slide is a Figure — same tokens, same caption logic.",
          },
        ]}
      />
    </ComponentDoc>

    <ComponentDoc
      meta={themePanelMeta}
      tokens={flattenTokens(themePanelTokens)}
    >
      <ThemePanel client:visible />
    </ComponentDoc>

    <ComponentDoc
      meta={tokenInspectorMeta}
      tokens={flattenTokens(tokenInspectorTokens)}
    >
      <token-inspector tiers={JSON.stringify(tiers)}></token-inspector>
      <p class="system__note">
        Toggle, then move the cursor (or tab) across this page — every
        element reveals the token custom properties that style it.
      </p>
    </ComponentDoc>
  </section>

  <section class="system__section" aria-labelledby="ai-heading">
    <h2 id="ai-heading">Machine-readable by design</h2>

    <div class="prose system__case">
      <h3>Problem</h3>
      <p>
        AI-assisted development has a failure mode that code review is bad
        at catching: an assistant references a token that does not exist.
        The CSS compiles, the custom property resolves to nothing, and a
        style silently disappears. The same assistant will hardcode a hex
        value under deadline pressure, or rebuild a component that already
        exists two files away. Prose rules — &ldquo;components never consume
        primitives&rdquo; — prevent none of this. They rely on every
        contributor, human or machine, reading and remembering them.
      </p>
      <p>
        A nine-component portfolio can absorb that risk. A token system that
        is meant to be reused across future projects cannot: every drift
        compounds with each new consumer.
      </p>

      <h3>Approach</h3>
      <p>
        Treat the design system as a data structure that can be queried and
        checked, not just text to interpret — Cristian Morales
        Achiardi&rsquo;s{" "}
        <a
          href="https://www.designsystemscollective.com/building-an-ai-ready-design-system-35e709f54edf"
          rel="external"
        >
          AI-ready design system
        </a>{" "}
        approach, scaled down to a system this size. Three parts:
      </p>
      <p>
        <strong>Executable governance.</strong> An auditor script encodes
        eleven rules in three groups: token hierarchy (primitives reference
        nothing, semantic references primitives, component references
        semantic, every reference resolves), authored CSS (no color
        literals, no px beyond hairlines, every custom property exists,
        components never consume primitives, BEM blocks match file names)
        and metadata (every component carries one, none is orphaned). It
        runs inside <code>npm run build</code> — a violation is a failed
        build, not a review comment.
      </p>
      <p>
        <strong>Component metadata.</strong> Every component ships a
        co-located JSON file holding the decisions that usually live in
        heads: use cases, anti-patterns with reasons and alternatives,
        selection criteria, consumed token prefixes, accessibility notes.
        AI tooling queries these files before creating or changing anything
        — extending an existing component beats building a new one.
      </p>
      <p>
        <strong>Deliberate restraint.</strong> The larger machinery of
        AI-ready systems — dependency indexes, adoption reports — is
        documented as growth triggers, not built ahead of need. At nine
        components a dependency graph is trivia; maintaining it would be
        pure staleness risk.
      </p>

      <h3>Decisions</h3>
      <p>
        <strong>One source for humans and machines.</strong> The component
        docs above are rendered from the same metadata files the tooling
        queries. There is no second, hand-written documentation that could
        drift — the docs <em>are</em> the data.
      </p>
      <p>
        <strong>Metadata lives next to the component.</strong> A co-located
        file moves, renames and dies with its component. The auditor treats
        an orphaned metadata file as an error, not a leftover.
      </p>
      <p>
        <strong>The pipeline is portable.</strong> Build, contrast proof and
        auditor read their paths from one config file. When a second project
        adopts the token layer, the governance moves with it unchanged —
        the rules are part of the system, not of this site.
      </p>

      <h3>Outcome</h3>
      <p>
        The auditor&rsquo;s first run — against a codebase written under the
        prose version of these exact rules — found 14 violations: six
        primitive-token usages across five components, plus the then-missing
        metadata files.
      </p>
      <pre class="system__audit-log" aria-label="Excerpt of the first audit run"><code>Design system audit: 14 violation(s)

src/components/Badge.astro
  ✘ [C4] var(--font-line-height-base) is a primitive —
         components consume component/semantic tokens only
src/components/Button.astro
  ✘ [C4] var(--font-weight-medium) is a primitive —
         components consume component/semantic tokens only
…</code></pre>
      <p>
        The rules had existed as prose the whole time; the violations
        shipped anyway. Two new semantic tokens fixed all six, and since
        then the invariants hold by construction: every build proves
        contrast for all 360 hues and all eleven rules before a single page
        renders.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .system__lead {
    margin-block-start: var(--space-stack-md);
    max-width: 65ch;
    font-size: var(--typography-lead-size);
    color: var(--color-text-secondary);
  }

  .system__case {
    margin-block-start: var(--space-stack-lg);
    max-width: 65ch;
  }

  .system__section {
    margin-block-start: var(--space-stack-xl);
  }

  /* Decisions as a scannable index: mono ordinal | title + two sentences —
     the site's ordinal vocabulary instead of a wall of bold paragraphs. */
  .system__decisions {
    list-style: none;
    margin: var(--space-stack-md) 0 0;
    padding: 0;
    max-width: 72ch;
  }

  .system__decision {
    display: grid;
    grid-template-columns: var(--space-inline-xl) 1fr;
    column-gap: var(--space-inline-lg);
    padding-block: var(--space-stack-md);
    border-block-start: 1px solid var(--color-border-default);
  }

  .system__decision:last-child {
    border-block-end: 1px solid var(--color-border-default);
  }

  .system__decision-index {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    font-weight: var(--typography-label-weight);
    color: var(--color-text-muted);
    padding-block-start: var(--space-stack-xs);
  }

  .system__decision-body {
    display: grid;
    gap: var(--space-stack-xs);
  }

  .system__decision-title {
    font-size: var(--typography-heading-sm-size);
  }

  .system__decision-body p {
    max-width: 60ch;
    color: var(--color-text-secondary);
  }

  .system__section h3 {
    margin-block-start: var(--space-stack-lg);
    margin-block-end: var(--space-stack-sm);
  }

  .system__note {
    max-width: 65ch;
    margin-block-end: var(--space-stack-sm);
    color: var(--color-text-secondary);
  }

  .system__ramps {
    display: grid;
    gap: var(--space-stack-md);
  }

  .system__token-reference {
    margin-block-start: var(--space-stack-md);
  }

  .system__accordion-demo {
    inline-size: 100%;
  }

  .system__audit-log {
    padding: var(--space-inset-lg);
    border: 1px solid var(--color-border-default);
    background: var(--color-surface-sunken);
    overflow-x: auto;
  }

  .system__demo-row {
    display: flex;
    gap: var(--space-inline-sm);
  }

  .system__timeline-demo {
    list-style: none;
    margin: 0;
    padding: 0;
    inline-size: 100%;
  }
</style>
