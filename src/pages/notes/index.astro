---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readingTime, formatDate } from "../../lib/notes";

const posts = (await getCollection("notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Notes"
  description="Random thoughts and small findings from Michael Giang's journey — design systems, tokens, patterns. Loose cadence, no promises."
>
  <h1>Notes</h1>
  <p class="annotations" aria-hidden="true">
    <code>{posts.length} {posts.length === 1 ? "entry" : "entries"}</code>
    <code>random thoughts</code>
    <code>no cadence</code>
  </p>
  <p class="notes__lead">
    Random thoughts from my journey — token decisions, patterns, small
    findings. Not a blog: entries appear when something is worth writing
    down, and we will see where this goes.
  </p>

  <!-- A journal, not a magazine: date column left, compact entry right —
       random thoughts should not be oversold by index typography. -->
  <div class="notes__log">
    {
      posts.map((post, i) => (
        <article class="notes__entry">
          <p class="notes__date" aria-hidden="true">
            {formatDate(post.data.date)}
          </p>
          <a class="notes__link" href={`/notes/${post.id}`}>
            <h2 class="notes__title">{post.data.title}</h2>
            <p class="notes__description">{post.data.description}</p>
            <p class="notes__meta" aria-hidden="true">
              entry {String(posts.length - i).padStart(3, "0")} ·{" "}
              {readingTime(post.body ?? "")} min read
            </p>
          </a>
        </article>
      ))
    }
  </div>
</BaseLayout>

<style>
  .notes__lead {
    max-width: 55ch;
    margin-block-start: var(--space-stack-md);
    font-size: var(--typography-lead-size);
    color: var(--color-text-secondary);
  }

  .notes__log {
    margin-block-start: var(--space-stack-xl);
    max-width: 72ch;
  }

  .notes__entry {
    display: grid;
    grid-template-columns: 1fr;
    padding-block: var(--space-stack-md);
    border-block-start: 1px solid var(--color-border-default);
  }

  .notes__entry:last-child {
    border-block-end: 1px solid var(--color-border-default);
  }

  @media (min-width: 40rem) {
    .notes__entry {
      grid-template-columns: 8rem 1fr;
      column-gap: var(--space-inline-lg);
    }
  }

  .notes__date {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
    padding-block-start: var(--space-stack-xs);
    white-space: nowrap;
  }

  .notes__link {
    display: grid;
    justify-items: start;
    gap: var(--space-stack-xs);
    color: inherit;
    text-decoration: none;
  }

  .notes__title {
    font-size: var(--typography-heading-sm-size);
    transition: color var(--motion-state-duration) var(--motion-state-easing);
  }

  .notes__link:hover .notes__title {
    color: var(--color-interactive-hover);
  }

  .notes__description {
    max-width: 55ch;
    color: var(--color-text-secondary);
  }

  .notes__meta {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
  }
</style>
