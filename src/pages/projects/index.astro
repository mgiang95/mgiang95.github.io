---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import Badge from "../../components/Badge.astro";

const featured = (
  await getCollection("projects", ({ data }) => data.featured)
).sort((a, b) => a.data.order - b.data.order);

const more = (
  await getCollection("projects", ({ data }) => !data.featured && !data.parent)
).sort((a, b) => a.data.order - b.data.order);

const moreRendered = await Promise.all(
  more.map(async (entry) => ({ entry, rendered: await render(entry) })),
);
---

<BaseLayout
  title="Projects"
  description="Case studies on design systems, UX patterns and component libraries — B2B and B2C."
>
  <h1>Projects</h1>
  <p class="projects__lead">
    Case studies with a focus on decisions: design systems, UX patterns and
    component libraries in B2B and B2C products.
  </p>

  <div class="projects__grid">
    {featured.map((project) => <ProjectCard project={project} />)}
  </div>

  <section class="projects__more" aria-labelledby="more-projects-heading">
    <h2 id="more-projects-heading">More projects</h2>
    <ul class="projects__more-list">
      {
        moreRendered.map(({ entry, rendered }) => (
          <li class="projects__more-item">
            <header class="projects__more-header">
              <h3 class="projects__more-title">{entry.data.title}</h3>
              <p class="projects__more-period">{entry.data.period}</p>
            </header>
            <div class="prose prose--compact">
              <rendered.Content />
            </div>
            <ul class="projects__more-keywords" aria-label="Key areas">
              {entry.data.keywords.map((keyword) => (
                <li>
                  <Badge>{keyword}</Badge>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .projects__lead {
    margin-block-start: var(--space-stack-md);
    max-width: 55ch;
    font-size: var(--typography-lead-size);
    color: var(--color-text-secondary);
  }

  .projects__grid {
    display: grid;
    gap: var(--space-stack-lg);
    margin-block-start: var(--space-stack-lg);
  }

  @media (min-width: 60rem) {
    .projects__grid {
      grid-template-columns: repeat(3, 1fr);
      column-gap: var(--space-inline-lg);
    }
  }

  .projects__more {
    margin-block-start: var(--space-stack-xl);
  }

  .projects__more-list {
    list-style: none;
    margin: var(--space-stack-md) 0 0;
    padding: 0;
  }

  .projects__more-item {
    display: grid;
    gap: var(--space-stack-xs);
    padding-block: var(--space-stack-md);
    border-block-start: 1px solid var(--color-border-default);
  }

  .projects__more-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-inline-md);
  }

  .projects__more-title {
    font-size: var(--typography-heading-sm-size);
  }

  .projects__more-period {
    color: var(--color-text-muted);
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    white-space: nowrap;
  }

  .projects__more-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
