---
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import Gallery from "../../components/Gallery.astro";

export async function getStaticPaths() {
  // Every project gets a page — since the draft pass, the smaller entries
  // carry full Problem/Approach/Outcome texts and the index table links here.
  const entries = await getCollection("projects");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const {
  title,
  subtitle,
  description,
  period,
  role,
  client,
  externalUrl,
  keywords,
  heroImage,
  gallery,
  achievements,
  parent,
} = entry.data;
const { Content } = await render(entry);
const parentEntry = parent ? await getEntry(parent) : undefined;
---

<BaseLayout title={title} description={description}>
  <article class="case">
    {
      parentEntry && (
        <p class="case__breadcrumb">
          <a href={`/projects/${parentEntry.id}`}>
            ← Part of: {parentEntry.data.title}
          </a>
        </p>
      )
    }
    {
      /* No annotations row here, unlike the other page headers: everything it
        could say is already in the facts list below — the period verbatim, and
        "N focus areas" is just a count of the badges next to it. An annotation
        that repeats the next paragraph is noise. */
    }
    <header class="case__header">
      <h1 class="case__title">{title}</h1>
      <p class="case__subtitle">{subtitle}</p>
    </header>

    {
      heroImage && (
        <Image
          class="case__hero"
          src={heroImage}
          alt=""
          widths={[720, 1200, 1800]}
          sizes="(min-width: 76rem) 72rem, 100vw"
        />
      )
    }

    <dl class="case__facts">
      <div class="case__fact">
        <dt>Role</dt>
        <dd>{role}</dd>
      </div>
      <div class="case__fact">
        <dt>Period</dt>
        <dd>{period}</dd>
      </div>
      {
        client && (
          <div class="case__fact">
            <dt>Client</dt>
            <dd>{externalUrl ? <a href={externalUrl}>{client}</a> : client}</dd>
          </div>
        )
      }
      <div class="case__fact">
        <dt>Key areas</dt>
        <dd>
          <ul class="case__keywords">
            {
              keywords.map((keyword) => (
                <li>
                  <Badge>{keyword}</Badge>
                </li>
              ))
            }
          </ul>
        </dd>
      </div>
    </dl>

    <div class="prose case__body">
      <Content />
    </div>

    {
      gallery && gallery.length > 0 && (
        <section class="case__gallery" aria-labelledby="gallery-heading">
          <h2 class="case__gallery-heading" id="gallery-heading">
            Gallery
          </h2>
          <Gallery label={`${title} screenshots`} images={gallery} />
        </section>
      )
    }

    {
      achievements && (
        <aside
          class="case__achievements"
          aria-labelledby="achievements-heading"
        >
          <h2 class="case__achievements-heading" id="achievements-heading">
            Key achievements
          </h2>
          <ul>
            {achievements.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </aside>
      )
    }

    <nav class="case__footer-nav" aria-label="Case study navigation">
      <a href="/projects">← All projects</a>
    </nav>
  </article>
</BaseLayout>

<style>
  /* One reading axis for the whole case. Every block lands in the centred
     reading column by default; only what is meant to break out — hero, spec
     band, figures, gallery — spans all three columns.

     The measure is declared once and reused by the nested grids below: the
     prose column only lines up with the heading above it as long as both
     grids resolve to identical columns, so that has to be one definition
     rather than two that happen to match. */
  .case {
    --case-measure: 1fr min(65ch, 100%) 1fr;

    display: grid;
    grid-template-columns: var(--case-measure);
    align-content: start;
  }

  .case > * {
    grid-column: 2;
  }

  /* Matched through `.case >` rather than on the class alone: Astro scopes a
     bare `*` into an attribute selector, which makes the rule above weigh
     (0,3,0) — heavier than a plain `.case__hero` (0,2,0) would. Naming the
     parent puts these at (0,4,0), so the breakout wins on structure instead
     of on !important. */
  .case > .case__hero,
  .case > .case__facts,
  .case > .case__body,
  .case > .case__gallery {
    grid-column: 1 / -1;
  }

  .case__breadcrumb {
    margin-block-end: var(--space-stack-md);
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
  }

  .case__header {
    display: grid;
    gap: var(--space-stack-sm);
    margin-block-end: var(--space-stack-lg);
  }

  .case__title {
    max-width: 30ch;
  }

  /* No max-width: the reading column already is the measure. */
  .case__subtitle {
    font-size: var(--typography-lead-size);
    color: var(--color-text-secondary);
  }

  .case__hero {
    inline-size: 100%;
    block-size: auto;
    border: 1px solid var(--color-border-default);
  }

  /* Single reading axis: the header, the facts band, the prose and every
     following section share one left edge (the container edge). The facts
     sit in a horizontal spec band between hero and text — no side rail that
     would push the prose off-axis and then run empty down the page. */
  /* Flex, not an auto-fit grid: equal-width columns stretched every entry to
     the same 1fr box, so a short value like "2017" sat in a column as wide as
     the client name and left a ragged trail of whitespace behind it. Here each
     fact hugs its content and the row is justified to the rule above and below
     it, like a line of justified type — the gap token stays the MINIMUM, the
     slack is shared out. A wrapped row falls back to the left, as the last
     line of justified text does.

     This holds because "Key areas" is by far the widest fact and therefore
     always wraps alone. A project whose badges are narrow enough to share the
     last row with another fact would push the two apart to opposite edges —
     if that shows up, give the keyword list flex-basis: 100% and it is a row
     of its own by construction rather than by luck. */
  .case__facts {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-stack-sm) var(--space-inline-xxl);
    margin-block: var(--space-stack-lg);
    padding-block: var(--space-inset-md);
    border-block: 1px solid var(--color-border-default);
  }

  .case__fact {
    display: grid;
    gap: var(--space-stack-xs);
  }

  .case__fact dt {
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
    color: var(--color-text-muted);
  }

  .case__fact dd {
    margin: 0;
  }

  .case__keywords {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Same measure as the article, so the prose column lands exactly under the
     heading: the side columns do the centring, and the text inside stays
     ranged left. No negative margins, no width calc — below the reading
     measure min(65ch, 100%) resolves to 100%, the side columns collapse to
     zero, and prose and figures share one edge without a media query. */
  .case__body {
    display: grid;
    grid-template-columns: var(--case-measure);
  }

  .case__body > :global(*) {
    grid-column: 2;
  }

  .case__body > :global(figure) {
    grid-column: 1 / -1;
  }

  /* Full-bleed like the figures, but its heading belongs to the reading
     column — so the section re-splits into the same measure. */
  .case__gallery {
    display: grid;
    grid-template-columns: var(--case-measure);
    margin-block-start: var(--space-stack-xl);
  }

  /* :global(*), not a scoped *: the <Gallery> root renders without this
     page's scope attribute (no class is passed through), so a scoped child
     selector would skip it and auto-place the gallery into the left gutter. */
  .case__gallery > :global(*) {
    grid-column: 1 / -1;
  }

  /* Same scoping rule as above: the parent has to be named, or the heading
     loses to the bare `*` rule and drifts out of the reading column. */
  .case__gallery > .case__gallery-heading {
    grid-column: 2;
    font-size: var(--typography-heading-sm-size);
    margin-block-end: var(--space-stack-sm);
  }

  .case__achievements {
    margin-block-start: var(--space-stack-xl);
    padding: var(--space-inset-lg);
    background: var(--color-surface-sunken);
    border-inline-start: var(--space-inline-xs) solid
      var(--color-surface-accent);
  }

  .case__achievements-heading {
    font-size: var(--typography-heading-sm-size);
    margin-block-end: var(--space-stack-sm);
  }

  /* List rendering (chevron markers, hanging indent) lives in global.css,
     shared with .prose — this only removes the default block margin. */
  .case__achievements ul {
    margin: 0;
  }

  .case__footer-nav {
    margin-block-start: var(--space-stack-xl);
    font-family: var(--typography-label-family);
    font-size: var(--typography-label-size);
  }
</style>
